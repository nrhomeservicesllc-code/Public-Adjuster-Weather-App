# Database (Supabase — get from supabase.com project settings)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# NextAuth — generate secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — get from console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cron security — random string to protect cron endpoints
CRON_SECRET="your-cron-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email notifications (Resend — get free API key at resend.com)
RESEND_API_KEY=""
EMAIL_FROM="ClaimCast <alerts@claimcast.app>"
